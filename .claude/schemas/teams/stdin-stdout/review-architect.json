{
  "$comment": "Stdin/stdout contract for architect-reviewer in review workflow",
  "stdin": {
    "agent": "architect-reviewer",
    "workflow": "review",
    "review_scope": {
      "changed_files": [
        {
          "path": "relative/path/to/file.go",
          "language": "go",
          "category": "source|test|config",
          "changed_lines": {"added": 80, "removed": 30},
          "is_new_file": false
        }
      ],
      "direct_imports": [
        {
          "path": "relative/path/to/dependency.go",
          "relationship": "imports|imported_by|shared_interface",
          "relevance": "Why this dependency matters for architectural review"
        }
      ],
      "total_files": 0,
      "languages_detected": ["go"]
    },
    "context": {
      "commit_message": "What this change is supposed to do",
      "pr_description": "PR description if available",
      "related_tickets": ["TC-XXX"],
      "branch_name": "feature/my-feature"
    },
    "focus_areas": {
      "module_boundaries": {
        "enabled": true,
        "priorities": ["encapsulation", "interface_design", "package_api_surface", "internal_vs_exported"]
      },
      "coupling": {
        "enabled": true,
        "priorities": ["dependency_direction", "circular_deps", "afferent_coupling", "efferent_coupling"]
      },
      "design_patterns": {
        "enabled": true,
        "priorities": ["composition_over_inheritance", "dependency_injection", "interface_segregation", "strategy_pattern"]
      },
      "change_impact": {
        "enabled": true,
        "priorities": ["ripple_effects", "breaking_changes", "backward_compatibility", "api_contract_stability"]
      },
      "testability": {
        "enabled": true,
        "priorities": ["mockability", "test_isolation", "test_surface_area", "integration_seams"]
      },
      "extensibility": {
        "enabled": true,
        "priorities": ["open_closed", "plugin_points", "configuration_over_code", "future_flexibility"]
      }
    },
    "architecture_context": {
      "module_map": "Description of how modules relate (or path to architecture doc)",
      "dependency_graph_summary": "High-level dependency flow",
      "known_architectural_debt": ["Known structural issues"],
      "design_decisions": ["Relevant ADRs or design decisions"]
    },
    "project_conventions": {
      "languages": ["go", "typescript"],
      "conventions_files": ["go.md"],
      "architecture_style": "Modular Go with small interfaces, composition",
      "max_module_loc": 1000,
      "max_dependencies_per_module": 10
    }
  },
  "stdout": {
    "reviewer": "architect-reviewer",
    "status": "complete|partial|failed",
    "overall_assessment": "APPROVE|WARNING|BLOCK",
    "summary": "1-2 sentence summary of structural findings",
    "structural_health_score": {
      "overall": "A|B|C|D|F",
      "module_boundaries": "A|B|C|D|F",
      "coupling": "A|B|C|D|F",
      "testability": "A|B|C|D|F",
      "extensibility": "A|B|C|D|F"
    },
    "findings": [
      {
        "id": "AR-1",
        "severity": "critical|warning|info",
        "category": "architecture",
        "subcategory": "circular_dependency|god_module|leaky_abstraction|tight_coupling|missing_interface|wrong_layer|broken_encapsulation",
        "files_involved": ["path/to/file1.go", "path/to/file2.go"],
        "line": 12,
        "end_line": 45,
        "title": "Brief issue title",
        "message": "Detailed description of structural issue",
        "pattern": "Name of the anti-pattern detected",
        "impact": "How this affects the system long-term",
        "recommendation": "Specific structural fix",
        "code_snippet": "Relevant code showing the issue",
        "sharp_edge_id": "circular-dependency|god-module|leaky-abstraction|feature-envy|shotgun-surgery|inappropriate-intimacy",
        "references": []
      }
    ],
    "dependency_analysis": {
      "new_dependencies_introduced": 0,
      "dependencies_removed": 0,
      "circular_risks": [],
      "coupling_changes": "Description of how coupling changed"
    },
    "files_reviewed": 0,
    "files_skipped": 0,
    "metadata": {
      "duration_ms": 0,
      "thinking_budget_used": 0,
      "attempt_number": 1
    }
  }
}
