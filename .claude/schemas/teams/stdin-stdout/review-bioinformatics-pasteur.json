{
  "$comment": "Stdin/stdout contract for Pasteur synthesizer in review-bioinformatics workflow. Pasteur is exact-matched (no suffix stripping needed).",
  "stdin": {
    "agent": "pasteur",
    "workflow": "review-bioinformatics",
    "description": "Synthesize domain reviewer findings into unified bioinformatics review report",
    "context": {
      "project_root": "/absolute/path/to/project",
      "team_dir": "/absolute/path/to/team/directory"
    },
    "wave_0_outputs": [
      {
        "reviewer_id": "genomics-reviewer",
        "stdout_file_path": "/absolute/path/to/team/dir/stdout_genomics-reviewer.json",
        "status": "completed|failed|timeout",
        "cost_usd": 0.0
      }
    ],
    "review_scope_summary": {
      "total_files": 0,
      "languages_detected": ["nextflow"],
      "file_categories": ["pipeline", "config"]
    },
    "omics_context": {
      "primary_domain": "genomics",
      "data_formats_detected": ["FASTQ", "BAM", "VCF"],
      "pipeline_tools_detected": ["BWA", "GATK"],
      "workflow_manager": "nextflow"
    }
  },
  "stdout": {
    "verdict": "BLOCK|WARNING|APPROVE",
    "summary": {
      "critical": 0,
      "warnings": 0,
      "info": 0,
      "cross_domain": 0
    },
    "cross_domain_issues": [
      {
        "title": "Issue title",
        "domains": ["genomics", "proteogenomics"],
        "severity": "critical|warning|info",
        "description": "Description of cross-domain issue"
      }
    ],
    "findings": [],
    "reviewers_completed": ["genomics-reviewer"],
    "reviewers_failed": [],
    "metadata": {
      "thinking_budget_used": 0
    }
  }
}
