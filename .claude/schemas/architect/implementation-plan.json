{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gogent-fortress/schemas/architect/implementation-plan.json",
  "title": "Implementation Plan Schema",
  "description": "Structured architect output for team-run automation. Maps 1:1 to worker.json stdin.",
  "version": "1.0.0",
  "type": "object",
  "required": ["version", "project", "tasks"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for forward compatibility"
    },
    "project": {
      "type": "object",
      "required": ["language", "conventions_file"],
      "properties": {
        "language": {
          "type": "string",
          "description": "Primary language (go, python, typescript, r)"
        },
        "conventions_file": {
          "type": "string",
          "description": "Conventions file name (go.md, python.md)"
        },
        "build_verification": {
          "type": "string",
          "description": "Build command (go build ./..., npm run build)"
        },
        "error_handling": {
          "type": "string"
        },
        "test_pattern": {
          "type": "string"
        },
        "architecture_notes": {
          "type": "string"
        },
        "patterns_to_follow": {
          "type": "array",
          "items": { "type": "string" }
        },
        "anti_patterns": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["task_id", "subject", "description", "agent", "target_packages", "acceptance_criteria"],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^task-\\d{3}$",
            "description": "Zero-padded ID: task-001, task-002"
          },
          "subject": {
            "type": "string",
            "description": "Short task title"
          },
          "description": {
            "type": "string",
            "description": "FULL implementation guidance — workers don't read specs.md"
          },
          "agent": {
            "type": "string",
            "description": "Agent ID from agents-index.json (go-pro, python-pro, etc.)"
          },
          "target_packages": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "related_files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "relevance"],
              "properties": {
                "path": { "type": "string" },
                "relevance": { "type": "string" }
              }
            }
          },
          "blocked_by": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "tests_required": {
            "type": "boolean",
            "default": true
          },
          "coverage_target": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Target test coverage percentage (e.g., 80 for 80%)"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
