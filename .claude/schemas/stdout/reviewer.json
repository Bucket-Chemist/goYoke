{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gogent-fortress/schemas/stdout/reviewer.json",
  "title": "Generic Reviewer Stdout Schema",
  "description": "Validates stdout for all review workflow reviewers (backend, frontend, standards, architect)",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "reviewer",
    "status",
    "overall_assessment",
    "summary",
    "findings",
    "files_reviewed",
    "files_skipped",
    "metadata"
  ],
  "properties": {
    "reviewer": {
      "type": "string",
      "enum": ["backend-reviewer", "frontend-reviewer", "standards-reviewer", "architect-reviewer"],
      "description": "Agent identifier"
    },
    "status": {
      "type": "string",
      "enum": ["complete", "partial", "failed"],
      "description": "Review completion status"
    },
    "overall_assessment": {
      "type": "string",
      "enum": ["APPROVE", "WARNING", "BLOCK"],
      "description": "Overall assessment verdict"
    },
    "summary": {
      "type": "string",
      "description": "1-2 sentence summary of findings"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "category", "file", "title", "message", "impact", "recommendation"],
        "properties": {
          "id": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "info"]
          },
          "category": {"type": "string"},
          "subcategory": {"type": "string"},
          "file": {"type": "string"},
          "line": {"type": "integer", "minimum": 0},
          "end_line": {"type": "integer", "minimum": 0},
          "title": {"type": "string"},
          "message": {"type": "string"},
          "impact": {"type": "string"},
          "recommendation": {"type": "string"},
          "code_snippet": {"type": "string"},
          "sharp_edge_id": {"type": "string"},
          "references": {
            "type": "array",
            "items": {"type": "string"}
          },
          "pattern": {"type": "string"},
          "principle": {"type": "string"},
          "files_involved": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "security_summary": {
      "type": "object",
      "description": "For backend-reviewer: security-specific metrics",
      "properties": {
        "injection_risks": {"type": "integer", "minimum": 0},
        "auth_issues": {"type": "integer", "minimum": 0},
        "secrets_exposure": {"type": "integer", "minimum": 0},
        "input_validation_gaps": {"type": "integer", "minimum": 0}
      }
    },
    "accessibility_summary": {
      "type": "object",
      "description": "For frontend-reviewer: accessibility-specific metrics",
      "properties": {
        "keyboard_issues": {"type": "integer", "minimum": 0},
        "screen_reader_issues": {"type": "integer", "minimum": 0},
        "aria_issues": {"type": "integer", "minimum": 0},
        "focus_issues": {"type": "integer", "minimum": 0}
      }
    },
    "complexity_score": {
      "type": "object",
      "description": "For standards-reviewer: complexity metrics",
      "properties": {
        "average_cyclomatic": {"type": "number", "minimum": 0},
        "max_cyclomatic": {"type": "integer", "minimum": 0},
        "functions_over_threshold": {"type": "integer", "minimum": 0},
        "god_functions": {"type": "integer", "minimum": 0}
      }
    },
    "structural_health_score": {
      "type": "object",
      "description": "For architect-reviewer: structural health grades",
      "properties": {
        "overall": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "F"]
        },
        "module_boundaries": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "F"]
        },
        "coupling": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "F"]
        },
        "testability": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "F"]
        },
        "extensibility": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "F"]
        }
      }
    },
    "dependency_analysis": {
      "type": "object",
      "description": "For architect-reviewer: dependency impact analysis",
      "properties": {
        "new_dependencies_introduced": {"type": "integer", "minimum": 0},
        "dependencies_removed": {"type": "integer", "minimum": 0},
        "circular_risks": {
          "type": "array",
          "items": {"type": "string"}
        },
        "coupling_changes": {"type": "string"}
      }
    },
    "files_reviewed": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of files successfully reviewed"
    },
    "files_skipped": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of files skipped"
    },
    "metadata": {
      "type": "object",
      "required": ["thinking_budget_used"],
      "properties": {
        "duration_ms": {"type": "integer", "minimum": 0},
        "thinking_budget_used": {"type": "integer", "minimum": 0},
        "attempt_number": {"type": "integer", "minimum": 1}
      }
    }
  },
  "additionalProperties": false
}
