{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goyoke-fortress/schemas/stdin/beethoven.json",
  "title": "Beethoven Stdin Schema",
  "description": "Validates stdin for Beethoven (synthesis) in braintrust workflow",
  "version": "1.0.0",
  "type": "object",
  "required": ["agent", "workflow", "context", "problem_brief", "pre_synthesis_path"],
  "properties": {
    "agent": {
      "type": "string",
      "const": "beethoven",
      "description": "Agent identifier"
    },
    "workflow": {
      "type": "string",
      "const": "braintrust",
      "description": "Workflow type"
    },
    "context": {
      "type": "object",
      "required": ["project_root", "team_dir"],
      "properties": {
        "project_root": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute path to project root"
        },
        "team_dir": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute path to team directory"
        }
      }
    },
    "problem_brief": {
      "type": "object",
      "required": ["title", "statement", "scope"],
      "properties": {
        "title": {"type": "string"},
        "statement": {"type": "string"},
        "scope": {
          "type": "object",
          "required": ["in_scope", "out_of_scope"],
          "properties": {
            "in_scope": {
              "type": "array",
              "items": {"type": "string"}
            },
            "out_of_scope": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "success_criteria": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "pre_synthesis_path": {
      "type": "string",
      "pattern": "^/",
      "description": "Absolute path to pre-synthesis.md generated by goyoke-team-prepare-synthesis inter-wave script. Beethoven reads this file at runtime via Read tool."
    },
    "einstein_analysis": {
      "type": "object",
      "description": "Optional: Full stdout from Einstein if available at stdin generation time"
    },
    "staff_architect_review": {
      "type": "object",
      "description": "Optional: Full stdout from Staff-Architect if available at stdin generation time"
    },
    "description": {
      "type": "string",
      "description": "Human-readable task summary for envelope builder compatibility"
    }
  },
  "additionalProperties": false
}
