{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gogent-fortress/schemas/stdin/staff-architect.json",
  "title": "Staff-Architect Stdin Schema",
  "description": "Validates stdin for Staff-Architect (practical critical review) in braintrust workflow",
  "version": "1.0.0",
  "type": "object",
  "required": ["agent", "workflow", "context", "problem_brief", "plan_to_review", "codebase_context", "review_focus"],
  "properties": {
    "agent": {
      "type": "string",
      "const": "staff-architect-critical-review",
      "description": "Agent identifier"
    },
    "workflow": {
      "type": "string",
      "const": "braintrust",
      "description": "Workflow type"
    },
    "context": {
      "type": "object",
      "required": ["project_root", "team_dir"],
      "properties": {
        "project_root": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute path to project root"
        },
        "team_dir": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute path to team directory"
        }
      }
    },
    "problem_brief": {
      "type": "object",
      "required": ["title", "statement", "scope"],
      "properties": {
        "title": {"type": "string"},
        "statement": {"type": "string"},
        "scope": {
          "type": "object",
          "required": ["in_scope", "out_of_scope", "affected_modules"],
          "properties": {
            "in_scope": {
              "type": "array",
              "items": {"type": "string"}
            },
            "out_of_scope": {
              "type": "array",
              "items": {"type": "string"}
            },
            "affected_modules": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "plan_to_review": {
      "type": "object",
      "required": ["source", "format", "content"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Path or inline content identifier"
        },
        "format": {
          "type": "string",
          "enum": ["markdown", "json"],
          "description": "Format of the plan content"
        },
        "content": {
          "type": "string",
          "description": "Full plan content (phases, tickets, dependencies, acceptance criteria)"
        },
        "assumptions_declared": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "codebase_context": {
      "type": "object",
      "required": ["architecture_summary", "key_files"],
      "properties": {
        "architecture_summary": {"type": "string"},
        "key_files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "relevance"],
            "properties": {
              "path": {"type": "string"},
              "relevance": {"type": "string"},
              "excerpt": {"type": "string"}
            }
          }
        },
        "existing_patterns": {
          "type": "array",
          "items": {"type": "string"}
        },
        "technical_debt": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "scout_metrics": {
      "type": "object",
      "properties": {
        "total_files": {"type": "integer", "minimum": 0},
        "total_loc": {"type": "integer", "minimum": 0},
        "complexity_score": {"type": "number", "minimum": 0},
        "recommended_tier": {
          "type": "string",
          "enum": ["sonnet", "opus"]
        }
      }
    },
    "review_focus": {
      "type": "object",
      "required": ["layers"],
      "properties": {
        "layers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "assumptions",
              "dependencies",
              "failure_modes",
              "cost_benefit",
              "testing",
              "architecture_smells",
              "contractor_readiness"
            ]
          }
        },
        "priority_concerns": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  },
  "additionalProperties": false
}
