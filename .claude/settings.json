{
  "model": "opus[1m]",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(stat:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(make:*)"
    ],
    "deny": [
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(*rm -rf*)",
      "Bash(*> /dev/*)",
      "Bash(*sudo*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gogent-load-context",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gogent-skill-guard",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gogent-validate",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gogent-direct-impl-check",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gogent-sharp-edge",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gogent-agent-endstate",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gogent-orchestrator-guard",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gogent-archive",
            "timeout": 30
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "user_settings|project_settings|local_settings",
        "hooks": [
          {
            "type": "command",
            "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gogent-config-guard",
            "timeout": 5
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gogent-instructions-audit",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "gofortress-standalone": {
      "command": "/home/doktersmol/Documents/GOgent-Fortress/bin/gofortress-mcp-standalone",
      "env": {
        "GOGENT_PROJECT_ROOT": "/home/doktersmol/Documents/GOgent-Fortress"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "minimumVersion": "2.1.69",
  "use_team_pattern": true,
  "trustedDirectories": [
    "/home/doktersmol",
    "/home/doktersmol/Documents"
  ]
}
