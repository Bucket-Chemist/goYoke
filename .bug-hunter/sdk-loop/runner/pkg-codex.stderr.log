+		t.Fatalf("Expected no error, got: %v", err)
+	}
+	if len(logs) != 1 {
+		t.Fatalf("Expected 1 log, got: %d", len(logs))
+	}
+	if logs[0].TaskDescription != largeTask {
+		t.Fatalf("Expected large task description to round-trip")
+	}
+
+	os.RemoveAll(filepath.Dir(globalPath))
+}
