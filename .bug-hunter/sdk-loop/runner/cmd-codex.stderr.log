   121	
   122		var respPayload mcp.PermGateResponsePayload
   123		if err := json.Unmarshal(ipcResp.Payload, &respPayload); err != nil {
   124			return "", fmt.Errorf("UDS connection failed: unmarshal response payload: %v", err)
   125		}
   126	
   127		return respPayload.Decision, nil
   128	}
   129	
   130	// isRefused returns true when err is a connection-refused error.
   131	func isRefused(err error) bool {
   132		if err == nil {
   133			return false
   134		}
   135		// net.OpError wraps a syscall.Errno on Unix.
   136		if netErr, ok := err.(*net.OpError); ok {
   137			return netErr.Op == "dial" && isErrnoRefused(netErr.Err)
   138		}
   139		return false
   140	}
   141	
   142	// isErrnoRefused inspects the inner error from a net.OpError.
   143	func isErrnoRefused(err error) bool {
   144		// Use string matching as a portable fallback — avoids syscall import on
   145		// all target platforms.
   146		if err == nil {
   147			return false
   148		}
   149		msg := err.Error()
   150		return msg == "connection refused" ||
   151			msg == "connect: connection refused"
   152	}
   153	
   154	// isTimeout returns true when err is a deadline-exceeded (timeout) error.
   155	func isTimeout(err error) bool {
   156		if err == nil {
   157			return false
   158		}
   159		if netErr, ok := err.(net.Error); ok {
   160			return netErr.Timeout()
   161		}
   162		return false
   163	}

