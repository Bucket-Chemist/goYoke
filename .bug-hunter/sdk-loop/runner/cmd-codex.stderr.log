+func commonRoot(paths []string) string {
+	if len(paths) == 0 {
+		return "."
+	}
+
+	common := normalizePathRoot(paths[0])
+	for _, path := range paths[1:] {
+		common = sharedPathPrefix(common, normalizePathRoot(path))
+		if common == "." || common == string(filepath.Separator) {
