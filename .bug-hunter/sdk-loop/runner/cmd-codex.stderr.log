+				return filepath.SkipDir
+			}
+			return nil
+		}
+
+		fileInfo, ok, err := collectFileInfo(path)
+		if err != nil {
+			return err
+		}
+		if ok {
+			files = append(files, fileInfo)
+		}
+		return nil
+	})
+	if err != nil {
+		return nil, fmt.Errorf("failed to walk directory: %w", err)
+	}
+	return files, nil
