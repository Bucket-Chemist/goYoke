+func sharedPathPrefix(a, b string) string {
+	if a == b {
+		return a
+	}
+
+	aParts := strings.Split(filepath.Clean(a), string(filepath.Separator))
+	bParts := strings.Split(filepath.Clean(b), string(filepath.Separator))
+	maxParts := len(aParts)
+	if len(bParts) < maxParts {
+		maxParts = len(bParts)
+	}
+
