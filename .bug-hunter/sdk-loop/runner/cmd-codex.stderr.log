+			// Skip unreadable paths
+			return nil
+		}
+
+		if d.IsDir() {
+			// Skip hidden directories and common vendor directories
+			name := d.Name()
+			if strings.HasPrefix(name, ".") || name == "vendor" || name == "node_modules" {
+				return filepath.SkipDir
+			}
+			return nil
+		}
+
