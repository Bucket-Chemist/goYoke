   157	// skipRemainingWaves sets all members in waves after fromWaveIdx to "skipped".
   158	// Uses updateMember for thread-safe status updates.
   159	func skipRemainingWaves(tr *TeamRunner, fromWaveIdx int) {
   160		tr.configMu.RLock()
   161		if tr.config == nil || fromWaveIdx+1 >= len(tr.config.Waves) {
   162			tr.configMu.RUnlock()
   163			return
   164		}
   165		totalWaves := len(tr.config.Waves)
   166		tr.configMu.RUnlock()
   167	
   168		// Skip all waves after fromWaveIdx
   169		for waveIdx := fromWaveIdx + 1; waveIdx < totalWaves; waveIdx++ {
   170			tr.configMu.RLock()
   171			memberCount := len(tr.config.Waves[waveIdx].Members)
   172			tr.configMu.RUnlock()
   173	
   174			for memIdx := 0; memIdx < memberCount; memIdx++ {
   175				// updateMember acquires writeMu then configMu - do NOT call while holding either lock
   176				if err := tr.updateMember(waveIdx, memIdx, func(m *Member) {
   177					m.Status = "skipped"
   178				}); err != nil {
   179					log.Printf("[ERROR] wave: failed to skip member at wave %d, member %d: %v", waveIdx, memIdx, err)
   180				}
   181			}
   182		}
   183	}

