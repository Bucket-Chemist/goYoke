    91	// spawnAndWaitWithBudget wraps spawnAndWait with budget reconciliation.
    92	// Reconciles estimated cost reservation with actual cost after spawn completes.
    93	func spawnAndWaitWithBudget(ctx context.Context, tr *TeamRunner, waveIdx, memIdx int, estimated float64) {
    94		// Get member info for actual cost extraction
    95		tr.configMu.RLock()
    96		if tr.config == nil || waveIdx >= len(tr.config.Waves) || memIdx >= len(tr.config.Waves[waveIdx].Members) {
    97			tr.configMu.RUnlock()
    98			log.Printf("ERROR: Invalid wave/member indices in budget reconciliation: wave=%d, member=%d", waveIdx, memIdx)
    99			return
   100		}
   101		memberName := tr.config.Waves[waveIdx].Members[memIdx].Name
   102		tr.configMu.RUnlock()
   103	
   104		// Spawn and wait (this calls the WaitGroup.Done internally)
   105		var wg sync.WaitGroup
   106		wg.Add(1)
   107		spawnAndWait(ctx, tr, waveIdx, memIdx, &wg)
   108		wg.Wait()
   109	
   110		// Extract actual cost from member after completion
   111		tr.configMu.RLock()
   112		actual := tr.config.Waves[waveIdx].Members[memIdx].CostUSD
   113		tr.configMu.RUnlock()
   114	
   115		// Reconcile budget: return reservation, deduct actual
   116		if err := tr.reconcileCost(estimated, actual); err != nil {
   117			log.Printf("[ERROR] wave: budget reconciliation failed for %s: %v", memberName, err)
   118		} else {
   119			log.Printf("[INFO] wave: reconciled budget for %s (estimated=$%.2f, actual=$%.2f, remaining=$%.2f)",
   120				memberName, estimated, actual, tr.BudgetRemaining())
   121		}
   122	}
