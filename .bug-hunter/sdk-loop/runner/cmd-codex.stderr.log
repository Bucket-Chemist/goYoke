    83	// parseStdin reads and parses the PreToolUse JSON from r with a timeout.
    84	// It returns the parsed event and the raw tool_input bytes for forwarding to
    85	// the TUI.
    86	//
    87	// The read runs in a goroutine so we can apply a timeout (stdin has no
    88	// deadline support).  If the timeout fires the goroutine is orphaned, but
    89	// this is acceptable: the binary exits immediately after parseStdin returns
    90	// an error, so the goroutine is cleaned up by process exit.
    91	func parseStdin(r io.Reader) (*toolEvent, []byte, error) {
    92		type result struct {
    93			event    *toolEvent
    94			rawInput []byte
    95			err      error
    96		}
    97	
    98		ch := make(chan result, 1)
    99	
   100		go func() {
   101			data, err := io.ReadAll(r)
   102			if err != nil {
   103				ch <- result{nil, nil, err}
   104				return
   105			}
   106			if len(data) == 0 {
   107				ch <- result{nil, nil, fmt.Errorf("empty stdin")}
   108				return
   109			}
   110	
   111			var ev toolEvent
   112			if err := json.Unmarshal(data, &ev); err != nil {
   113				ch <- result{nil, nil, fmt.Errorf("invalid JSON: %w", err)}
   114				return
   115			}
