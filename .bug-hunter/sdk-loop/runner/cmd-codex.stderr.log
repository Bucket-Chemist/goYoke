    24	
    25		// Handle piped input (stdin file list)
    26		if target == "-" {
    27			scanner := bufio.NewScanner(os.Stdin)
    28			var files []string
    29			for scanner.Scan() {
    30				line := strings.TrimSpace(scanner.Text())
    31				if line != "" {
    32					files = append(files, line)
    33				}
    34			}
    35			if len(files) == 0 {
    36				fmt.Fprintf(os.Stderr, "Error: no files provided via stdin\n")
    37				os.Exit(2)
    38			}
    39			// Use directory of first file as target
    40			target = filepath.Dir(files[0])
    41		}
    42	
    43		// Validate target exists
    44		if _, err := os.Stat(target); os.IsNotExist(err) {
    45			fmt.Fprintf(os.Stderr, "Error: target not found: %s\n", target)
    46			os.Exit(2)
    47		}
    48	
    49		// Run native scout
    50		report, err := runScout(target, instruction)
    51		if err != nil {
    52			fmt.Fprintf(os.Stderr, "Error: %v\n", err)
    53			os.Exit(1)
    54		}
    55	
    56		// Determine output path
    57		outputPath := os.Getenv("SCOUT_OUTPUT")
    58		if outputPath == "" {
    59			// Check for --output flag
    60			for i, arg := range os.Args {
    61				if strings.HasPrefix(arg, "--output=") {
    62					outputPath = strings.TrimPrefix(arg, "--output=")
    63				} else if arg == "--output" && i+1 < len(os.Args) {
    64					outputPath = os.Args[i+1]
    65				}
    66			}
    67		}
    68	
    69		// Marshal JSON
    70		data, err := json.MarshalIndent(report, "", "  ")
    71		if err != nil {
