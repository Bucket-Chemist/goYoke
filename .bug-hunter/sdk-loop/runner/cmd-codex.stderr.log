    55	// absent.
    56	func CheckCache(sessionID, toolName string) (string, bool) {
    57		m, err := loadCache(sessionID)
    58		if err != nil {
    59			return "", false
    60		}
    61		decision, ok := m[toolName]
    62		return decision, ok
