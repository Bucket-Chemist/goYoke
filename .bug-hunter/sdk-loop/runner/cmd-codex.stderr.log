   124	// runInterWaveScript executes a script between waves.
   125	// Passes teamDir as the first argument to the script.
   126	func runInterWaveScript(ctx context.Context, scriptPath string, teamDir string) error {
   127		log.Printf("[INFO] wave: executing inter-wave script: %s %s", scriptPath, teamDir)
   128		cmd := exec.CommandContext(ctx, scriptPath, teamDir)
   129		cmd.Dir = teamDir
   130		output, err := cmd.CombinedOutput()
   131		if err != nil {
   132			return fmt.Errorf("inter-wave script %s failed: %w\noutput: %s", scriptPath, err, string(output))
   133		}
   134		log.Printf("[INFO] wave: inter-wave script %s completed successfully", scriptPath)
   135		return nil
   136	}
