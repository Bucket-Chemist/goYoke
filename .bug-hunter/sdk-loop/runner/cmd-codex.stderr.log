    88	// runScout executes the native scout with synthetic fallback.
    89	func runScout(target, instruction string) (*ScoutReport, error) {
    90		// Run native scout
    91		scout := &NativeScout{Target: target, Instruction: instruction}
    92		report, err := scout.Run()
    93	
    94		if err == nil {
    95			return report, nil
    96		}
    97	
    98		// Native failed - synthetic fallback (always succeeds)
    99		log.Printf("Native scout failed: %v, generating synthetic report", err)
   100		return generateSyntheticReport(target, err, nil), nil
   101	}
   102	
   103	// atomicWrite writes data to a file atomically using temp + rename.
   104	func atomicWrite(path string, data []byte) error {
   105		// Ensure directory exists
   106		dir := filepath.Dir(path)
   107		if err := os.MkdirAll(dir, 0755); err != nil {
   108			return fmt.Errorf("failed to create directory: %w", err)
   109		}
   110	
   111		// Write to temp file
   112		tmpPath := path + ".tmp"
   113		if err := os.WriteFile(tmpPath, data, 0644); err != nil {
   114			return fmt.Errorf("failed to write temp file: %w", err)
   115		}
   116	
   117		// Atomic rename
   118		if err := os.Rename(tmpPath, path); err != nil {
   119			os.Remove(tmpPath) // Clean up temp file
   120			return fmt.Errorf("failed to rename temp file: %w", err)

