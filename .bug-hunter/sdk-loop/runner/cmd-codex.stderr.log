    11	
    12	// cachePath returns the file path for the session permission cache.
    13	// Uses $XDG_RUNTIME_DIR when set, otherwise falls back to /tmp.
    14	func cachePath(sessionID string) string {
    15		dir := os.Getenv("XDG_RUNTIME_DIR")
    16		if dir == "" {
    17			dir = os.TempDir()
    18		}
    19		sum := sha256.Sum256([]byte(sessionID))
    20		return filepath.Join(dir, fmt.Sprintf("gofortress-perm-cache-%s.json", hex.EncodeToString(sum[:])))
    21	}
    22	
    23	// loadCache reads the cache file for sessionID.
    24	// Returns an empty map when the file does not exist (first run).
    25	func loadCache(sessionID string) (map[string]string, error) {
    26		path := cachePath(sessionID)
    27		data, err := os.ReadFile(path)
    28		if os.IsNotExist(err) {
    29			return make(map[string]string), nil
    30		}
    31		if err != nil {
    32			return nil, fmt.Errorf("read cache: %w", err)
    33		}
    34		var m map[string]string
    35		if err := json.Unmarshal(data, &m); err != nil {
    36			// Corrupt cache — start fresh rather than failing hard.
    37			return make(map[string]string), nil
    38		}
    39		return m, nil
    40	}
    41	
    42	// saveCache persists the cache map to disk with mode 0600.
    43	func saveCache(sessionID string, m map[string]string) error {
    44		data, err := json.Marshal(m)
    45		if err != nil {
    46			return fmt.Errorf("marshal cache: %w", err)
    47		}
    48		path := cachePath(sessionID)
    49		// WriteFile with restricted permissions — cache may contain tool names.
    50		return os.WriteFile(path, data, 0600)
