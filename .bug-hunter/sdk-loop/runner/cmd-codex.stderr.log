   138	// checkWaveFailures returns names of failed members in the given wave.
   139	// Reads member statuses under RLock.
   140	func checkWaveFailures(tr *TeamRunner, waveIdx int) []string {
   141		tr.configMu.RLock()
   142		defer tr.configMu.RUnlock()
   143	
   144		if tr.config == nil || waveIdx >= len(tr.config.Waves) {
   145			return nil
   146		}
   147	
   148		var failed []string
   149		for _, member := range tr.config.Waves[waveIdx].Members {
   150			if member.Status == "failed" {
   151				failed = append(failed, member.Name)
   152			}
   153		}
   154		return failed
   155	}
