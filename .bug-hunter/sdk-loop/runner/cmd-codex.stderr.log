+		}
+		return nil
+	})
+	if err != nil {
+		return nil, fmt.Errorf("failed to walk directory: %w", err)
+	}
+	return files, nil
+}
+
+func collectFileInfo(path string) (FileInfo, bool, error) {
+	ext := filepath.Ext(path)
