+				dirFiles, err := collectFilesFromDir(path)
+				if err != nil {
+					return nil, err
+				}
+				files = append(files, dirFiles...)
+				continue
+			}
+
+			fileInfo, ok, err := collectFileInfo(path)
+			if err != nil {
