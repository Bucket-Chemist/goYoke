   117			// Re-marshal tool_input for forwarding to the TUI.  We cannot use
   118			// the original bytes directly because the outer JSON may contain more
   119			// fields; we only want the tool_input value.
   120			rawInput, err := json.Marshal(ev.ToolInput)
   121			if err != nil {
   122				rawInput = []byte("{}")
   123			}
   124	
   125			ch <- result{&ev, rawInput, nil}
