   634	
   635	// parseCLIOutput parses Claude CLI output in either NDJSON (stream-json) or
   636	// JSON array (legacy json) format. Returns the extracted result entry data.
   637	func parseCLIOutput(output []byte) (*cliOutput, error) {
   638		var entries []json.RawMessage
   639	
   640		// Try NDJSON first (stream-json format: one JSON object per line)
   641		trimmed := bytes.TrimSpace(output)
   642		if len(trimmed) == 0 {
   643			return nil, fmt.Errorf("CLI output is empty")
   644		}
   645	
   646		if trimmed[0] == '[' {
   647			// Legacy JSON array format
   648			if err := json.Unmarshal(trimmed, &entries); err != nil {
   649				return nil, fmt.Errorf("CLI output not valid JSON array: %w", err)
   650			}
   651		} else {
   652			// NDJSON format (stream-json): one JSON object per line
   653			scanner := bufio.NewScanner(bytes.NewReader(trimmed))
   654			scanner.Buffer(make([]byte, 0, 1024*1024), 10*1024*1024) // 10MB max line
   655			for scanner.Scan() {
   656				line := bytes.TrimSpace(scanner.Bytes())
   657				if len(line) == 0 {
   658					continue
   659				}
   660				entries = append(entries, json.RawMessage(append([]byte{}, line...)))
   661			}
   662			if err := scanner.Err(); err != nil {
   663				return nil, fmt.Errorf("scanning NDJSON output: %w", err)
   664			}
   665		}
   666	
   667		if len(entries) == 0 {
   668			return nil, fmt.Errorf("CLI output has no entries")
   669		}
   670	
   671		// Find the "result" entry
   672		for _, entry := range entries {
   673			var partial struct {
   674				Type             string          `json:"type"`
   675				Subtype          string          `json:"subtype"`
   676				Result           string          `json:"result"`
   677				StructuredOutput json.RawMessage `json:"structured_output"`
   678				Cost             float64         `json:"total_cost_usd"`
   679				IsError          bool            `json:"is_error"`
   680				Session          string          `json:"session_id"`
   681			}
   682	
   683			if err := json.Unmarshal(entry, &partial); err != nil {
   684				continue
   685			}
   686	
   687			if partial.Type == "result" {
   688				result := partial.Result
   689				// When constrained decoding is active, structured_output contains
   690				// the schema-enforced JSON. Use it instead of the text result.
   691				if len(partial.StructuredOutput) > 0 && string(partial.StructuredOutput) != "null" {
   692					result = string(partial.StructuredOutput)
   693				}
   694				return &cliOutput{
   695					Result:       result,
   696					TotalCostUSD: partial.Cost,
   697					IsError:      partial.IsError,
   698					SessionID:    partial.Session,
   699				}, nil
   700			}
   701		}
   702	
   703		return nil, fmt.Errorf("no result entry found in CLI output")
   704	}
