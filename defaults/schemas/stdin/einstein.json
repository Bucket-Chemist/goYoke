{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goyoke-fortress/schemas/stdin/einstein.json",
  "title": "Einstein Stdin Schema",
  "description": "Validates stdin for Einstein (theoretical analysis) in braintrust workflow",
  "version": "1.0.0",
  "type": "object",
  "required": ["agent", "workflow", "context", "problem_brief", "codebase_context"],
  "properties": {
    "agent": {
      "type": "string",
      "const": "einstein",
      "description": "Agent identifier"
    },
    "workflow": {
      "type": "string",
      "const": "braintrust",
      "description": "Workflow type"
    },
    "context": {
      "type": "object",
      "required": ["project_root", "team_dir"],
      "properties": {
        "project_root": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute path to project root"
        },
        "team_dir": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute path to team directory"
        }
      }
    },
    "problem_brief": {
      "type": "object",
      "required": ["title", "statement", "scope", "complexity_signals", "constraints"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Brief problem title"
        },
        "statement": {
          "type": "string",
          "description": "Full problem statement as written by Mozart after clarification interview"
        },
        "scope": {
          "type": "object",
          "required": ["in_scope", "out_of_scope", "affected_modules"],
          "properties": {
            "in_scope": {
              "type": "array",
              "items": {"type": "string"},
              "description": "List of things explicitly in scope"
            },
            "out_of_scope": {
              "type": "array",
              "items": {"type": "string"},
              "description": "List of things explicitly excluded"
            },
            "affected_modules": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Module paths relevant to the problem"
            }
          }
        },
        "complexity_signals": {
          "type": "object",
          "properties": {
            "cross_module": {"type": "boolean"},
            "novel_problem": {"type": "boolean"},
            "security_critical": {"type": "boolean"},
            "performance_critical": {"type": "boolean"},
            "estimated_files_affected": {"type": "integer", "minimum": 0}
          }
        },
        "prior_art": {
          "type": "object",
          "properties": {
            "existing_patterns": {
              "type": "array",
              "items": {"type": "string"}
            },
            "previous_attempts": {
              "type": "array",
              "items": {"type": "string"}
            },
            "related_tickets": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "analysis_axes": {
          "type": "object",
          "properties": {
            "conceptual_focus": {
              "type": "array",
              "items": {"type": "string"}
            },
            "novel_angles": {
              "type": "array",
              "items": {"type": "string"}
            },
            "first_principles": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "constraints": {
          "type": "object",
          "required": ["technical", "organizational", "compatibility"],
          "properties": {
            "technical": {
              "type": "array",
              "items": {"type": "string"}
            },
            "organizational": {
              "type": "array",
              "items": {"type": "string"}
            },
            "compatibility": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "codebase_context": {
      "type": "object",
      "required": ["architecture_summary", "key_files"],
      "properties": {
        "architecture_summary": {
          "type": "string",
          "description": "High-level description of system architecture"
        },
        "key_files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "relevance"],
            "properties": {
              "path": {"type": "string"},
              "relevance": {"type": "string"},
              "excerpt": {"type": "string"}
            }
          }
        },
        "dependency_graph": {"type": "string"},
        "conventions": {"type": "string"}
      }
    },
    "scout_findings": {
      "type": "object",
      "properties": {
        "metrics": {
          "type": "object",
          "properties": {
            "total_files": {"type": "integer", "minimum": 0},
            "total_loc": {"type": "integer", "minimum": 0},
            "languages": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "summary": {"type": "string"}
      }
    },
    "description": {
      "type": "string",
      "description": "Human-readable task summary for envelope builder compatibility"
    }
  },
  "additionalProperties": false
}
