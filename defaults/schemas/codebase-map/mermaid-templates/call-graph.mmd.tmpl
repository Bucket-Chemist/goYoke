graph LR
    %% Call graph for module: {{.ModuleName}}
    %% Showing functions with 2+ connections
    %% Scoping: if >30 functions, only entrypoints + 2-hop neighbors are shown

    {{range .Functions}}
    {{.ID}}["{{.Name}}"]
    {{end}}

    {{range .Calls}}
    {{.Caller}} --> {{.Callee}}
    {{end}}

    %% Highlight entry points
    classDef entrypoint fill:#fff3e0,stroke:#e65100
    {{range .Entrypoints}}
    class {{.ID}} entrypoint
    {{end}}
