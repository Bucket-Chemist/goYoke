{
  "$comment": "Stdin/stdout contract for bioinformatics domain reviewers (genomics, proteomics, proteogenomics, proteoform, mass-spec, bioinformatician) in review-bioinformatics workflow. Shared via role fallback: genomics-reviewer -> review-bioinformatics-reviewer.json",
  "stdin": {
    "agent": "genomics-reviewer|proteomics-reviewer|proteogenomics-reviewer|proteoform-reviewer|mass-spec-reviewer|bioinformatician-reviewer",
    "workflow": "review-bioinformatics",
    "description": "Bioinformatics domain review: pipeline code, data processing, format compliance",
    "context": {
      "project_root": "/absolute/path/to/project",
      "team_dir": "/absolute/path/to/team/directory"
    },
    "review_scope": {
      "files": [
        {
          "path": "relative/path/to/pipeline.nf",
          "language": "nextflow|snakemake|python|r|bash",
          "category": "pipeline|data-processing|config|statistical-analysis",
          "changed_lines": {"added": 45, "removed": 12},
          "is_new_file": false
        }
      ],
      "total_files": 0,
      "languages_detected": ["nextflow"]
    },
    "git_context": {
      "commit_message": "What this change is supposed to do",
      "branch_name": "feature/my-pipeline"
    },
    "focus_areas": {
      "alignment": true,
      "variant_calling": true,
      "reference_handling": true,
      "format_compliance": true,
      "annotation": true
    },
    "project_conventions": {},
    "omics_context": {
      "primary_domain": "genomics|proteomics|proteogenomics|proteoform|mass-spectrometry|pipeline|mixed",
      "data_formats_detected": ["FASTQ", "BAM", "VCF"],
      "pipeline_tools_detected": ["BWA", "GATK"],
      "workflow_manager": "nextflow|snakemake|wdl|cwl|null"
    }
  },
  "stdout": {
    "schema_id": "reviewer",
    "reviewer": "genomics-reviewer",
    "status": "complete|partial|failed",
    "overall_assessment": "APPROVE|WARNING|BLOCK",
    "summary": "1-2 sentence summary of findings",
    "findings": [
      {
        "id": "GEN-1",
        "severity": "CRITICAL|HIGH|MEDIUM|LOW|INFO",
        "category": "alignment|variant-calling|reference|annotation|format-compliance|cross-stage",
        "file": "relative/path/to/pipeline.nf",
        "line": 42,
        "end_line": 48,
        "title": "Brief issue title",
        "message": "Detailed description of the issue",
        "impact": "Biological/analytical consequence",
        "recommendation": "Specific fix recommendation",
        "code_snippet": "Relevant code from the file",
        "sharp_edge_id": "genomics-ref-wrong-build|genomics-vc-no-normalization|...",
        "references": ["Link to relevant documentation"]
      }
    ],
    "files_reviewed": 0,
    "files_skipped": 0,
    "metadata": {
      "duration_ms": 0,
      "thinking_budget_used": 0,
      "attempt_number": 1
    }
  }
}
