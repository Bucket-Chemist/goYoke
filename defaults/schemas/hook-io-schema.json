{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goyoke-fortress/schemas/hook-io-schema.json",
  "title": "goYoke Hook I/O Schema",
  "description": "Defines input/output contracts for Claude Code hooks",
  "version": "1.0.0",

  "definitions": {
    "HookDecision": {
      "type": "string",
      "enum": ["allow", "block", "modify"]
    },

    "PreToolUseInput": {
      "type": "object",
      "required": ["hook_event_name", "session_id", "tool_name"],
      "properties": {
        "hook_event_name": { "const": "PreToolUse" },
        "session_id": { "type": "string" },
        "tool_name": { "type": "string" },
        "tool_input": { "type": "object" }
      }
    },

    "PreToolUseOutput": {
      "type": "object",
      "required": ["decision"],
      "properties": {
        "decision": { "$ref": "#/definitions/HookDecision" },
        "reason": { "type": "string" },
        "hookSpecificOutput": {
          "type": "object",
          "properties": {
            "hookEventName": { "const": "PreToolUse" },
            "permissionDecision": {
              "type": "string",
              "enum": ["allow", "deny"]
            },
            "permissionDecisionReason": { "type": "string" },
            "nestingLevel": { "type": "integer" },
            "suggestion": { "type": "string" }
          }
        }
      }
    },

    "SubagentStopInput": {
      "type": "object",
      "required": ["hook_event_name", "session_id", "agent_id", "agent_type", "status"],
      "properties": {
        "hook_event_name": { "const": "SubagentStop" },
        "session_id": { "type": "string" },
        "agent_id": { "type": "string" },
        "agent_type": { "type": "string" },
        "child_count": { "type": "integer", "default": 0 },
        "status": {
          "type": "string",
          "enum": ["complete", "error", "timeout"]
        }
      }
    },

    "SubagentStopOutput": {
      "type": "object",
      "required": ["decision"],
      "properties": {
        "decision": { "$ref": "#/definitions/HookDecision" },
        "reason": { "type": "string" },
        "message": { "type": "string" },
        "error": { "type": "string" },
        "hookSpecificOutput": {
          "type": "object",
          "properties": {
            "hookEventName": { "const": "SubagentStop" },
            "permissionDecision": {
              "type": "string",
              "enum": ["allow", "deny"]
            },
            "permissionDecisionReason": { "type": "string" },
            "agentId": { "type": "string" },
            "requiredDelegations": { "type": "integer" },
            "actualDelegations": { "type": "integer" },
            "suggestion": { "type": "string" }
          }
        }
      }
    },

    "PostToolUseInput": {
      "type": "object",
      "required": ["hook_event_name", "session_id", "tool_name", "tool_result"],
      "properties": {
        "hook_event_name": { "const": "PostToolUse" },
        "session_id": { "type": "string" },
        "tool_name": { "type": "string" },
        "tool_input": { "type": "object" },
        "tool_result": { "type": "object" }
      }
    },

    "PostToolUseOutput": {
      "type": "object",
      "required": ["decision"],
      "properties": {
        "decision": { "$ref": "#/definitions/HookDecision" },
        "additionalContext": { "type": "string" }
      }
    }
  },

  "oneOf": [
    {
      "title": "PreToolUse Event",
      "properties": {
        "input": { "$ref": "#/definitions/PreToolUseInput" },
        "output": { "$ref": "#/definitions/PreToolUseOutput" }
      }
    },
    {
      "title": "SubagentStop Event",
      "properties": {
        "input": { "$ref": "#/definitions/SubagentStopInput" },
        "output": { "$ref": "#/definitions/SubagentStopOutput" }
      }
    },
    {
      "title": "PostToolUse Event",
      "properties": {
        "input": { "$ref": "#/definitions/PostToolUseInput" },
        "output": { "$ref": "#/definitions/PostToolUseOutput" }
      }
    }
  ]
}
