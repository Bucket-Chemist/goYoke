{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "2.2.0",
  "description": "Minimal test routing schema for simulation harness",
  "updated": "2026-01-22",

  "tiers": {
    "haiku": {
      "description": "Mechanical work tier",
      "model": "haiku",
      "thinking": false,
      "max_thinking_budget": 0,
      "cost_per_1k_tokens": 0.0005,
      "patterns": ["search", "find", "count"],
      "tools": ["Read", "Glob", "Grep"],
      "thresholds": {
        "max_files": 5,
        "max_lines": 500,
        "max_tokens_estimate": 10000
      },
      "agents": ["codebase-search", "haiku-scout"]
    },
    "haiku_thinking": {
      "description": "Structured reasoning tier",
      "model": "haiku",
      "thinking": true,
      "max_thinking_budget": 6000,
      "cost_per_1k_tokens": 0.001,
      "patterns": ["scaffold", "document", "review"],
      "tools": ["Read", "Write", "Edit"],
      "thresholds": {
        "max_files": 10,
        "max_lines": 1000,
        "max_tokens_estimate": 25000
      },
      "agents": ["scaffolder", "tech-docs-writer", "code-reviewer", "librarian"]
    },
    "sonnet": {
      "description": "Reasoning work tier",
      "model": "sonnet",
      "thinking": true,
      "max_thinking_budget": 16000,
      "cost_per_1k_tokens": 0.009,
      "patterns": ["implement", "refactor", "debug"],
      "tools": ["Read", "Write", "Edit", "Bash", "Task"],
      "thresholds": {
        "max_files": 20,
        "max_lines": 5000,
        "max_tokens_estimate": 50000
      },
      "agents": ["python-pro", "go-pro", "r-pro", "orchestrator", "architect"]
    },
    "opus": {
      "description": "Deep analysis tier - BLOCKED via Task",
      "model": "opus",
      "thinking": true,
      "max_thinking_budget": 32000,
      "cost_per_1k_tokens": 0.045,
      "patterns": ["einstein", "deep analysis"],
      "tools": ["*"],
      "invocation": "/einstein (NOT Task tool)",
      "task_invocation_blocked": true,
      "escalation_protocol": "escalate_to_einstein",
      "thresholds": {
        "max_files": null,
        "max_lines": null,
        "max_tokens_estimate": null
      },
      "agents": ["einstein"]
    }
  },

  "tier_levels": {
    "description": "Numeric levels for tier comparison in delegation ceiling",
    "haiku": 1,
    "haiku_thinking": 2,
    "sonnet": 3,
    "opus": 4,
    "external": 0
  },

  "delegation_ceiling": {
    "enabled": true,
    "default": "sonnet",
    "source_file": ".claude/tmp/max_delegation",
    "allowed_from_tier": {
      "haiku": ["haiku"],
      "haiku_thinking": ["haiku", "haiku_thinking"],
      "sonnet": ["haiku", "haiku_thinking", "sonnet"],
      "opus": ["haiku", "haiku_thinking", "sonnet", "opus"]
    }
  },

  "scout_protocol": {
    "enabled": true,
    "trigger_threshold_files": 3,
    "model": "haiku",
    "output_format": "json",
    "fields_required": ["file_count", "loc", "complexity_signals", "recommended_tier"]
  },

  "escalation_rules": {
    "failure_threshold": 3,
    "auto_capture_sharp_edge": true,
    "sonnet_to_opus": {
      "trigger": "orchestrator fails 3x OR explicitly requested",
      "protocol": "escalate_to_einstein",
      "mechanism": "Generate GAP document at .claude/tmp/einstein-gap-{timestamp}.md, notify user to run /einstein"
    }
  },

  "compound_triggers": {
    "enabled": true,
    "patterns": [
      {
        "triggers": ["large-context", "synthesize"],
        "target": "orchestrator",
        "reason": "multi-source synthesis"
      }
    ]
  },

  "cost_thresholds": {
    "direct_execution_max": 0.01,
    "scout_break_even": 0.02,
    "delegation_overhead": 0.005
  },

  "override": {
    "force_delegation_flag": "--force-delegation",
    "direct_execution_phrase": "do it directly"
  },

  "subagent_types": {
    "Explore": {
      "description": "Read-only exploration",
      "tools_granted": ["Read", "Glob", "Grep", "WebFetch", "WebSearch"],
      "tools_denied": ["Write", "Edit", "Bash", "Task"]
    },
    "general-purpose": {
      "description": "Full tool access for implementation",
      "tools_granted": ["*"],
      "tools_denied": []
    },
    "Plan": {
      "description": "Planning and coordination",
      "tools_granted": ["Read", "Glob", "Grep", "Task", "TodoWrite"],
      "tools_denied": ["Write", "Edit"]
    }
  },

  "delegation_rules": {
    "prompt_must_include": "AGENT:",
    "max_agents_per_task": 5,
    "require_explicit_model": false
  },

  "agent_subagent_mapping": {
    "codebase-search": "Explore",
    "haiku-scout": "Explore",
    "code-reviewer": "Explore",
    "librarian": "Explore",
    "tech-docs-writer": "general-purpose",
    "scaffolder": "general-purpose",
    "python-pro": "general-purpose",
    "go-pro": "general-purpose",
    "r-pro": "general-purpose",
    "orchestrator": "Plan",
    "architect": "Plan",
    "einstein": "general-purpose"
  },

  "blocked_patterns": {
    "task_patterns": [
      {
        "pattern": "model.*opus",
        "reason": "Task(opus) blocked - use /einstein",
        "enforcement": "PreToolUse hook"
      }
    ]
  },

  "meta_rules": {
    "routing_violations_log": ".claude/memory/routing-violations.jsonl",
    "sharp_edges_log": ".claude/memory/sharp-edges.jsonl",
    "attention_gate_interval": 10
  }
}
