{
  "id": "S004_mixed_artifacts",
  "description": "Session with multiple artifact types - violations, sharp edges, decisions",
  "setup": {
    "create_dirs": [".claude/memory", ".claude/tmp"],
    "files": {
      ".claude/memory/routing-violations.jsonl": "{\"timestamp\":1705708800,\"agent\":\"test-agent\",\"violation_type\":\"tier_mismatch\",\"expected_tier\":\"haiku\",\"actual_tier\":\"sonnet\"}",
      ".claude/memory/pending-learnings.jsonl": "{\"file\":\"test.go\",\"error_type\":\"syntax_error\",\"consecutive_failures\":3,\"timestamp\":1705708800,\"context\":\"Tool: Edit\"}",
      ".claude/memory/decisions.json": "[{\"id\":\"dec-001\",\"decision\":\"Use Go for CLI\",\"rationale\":\"Performance\"}]"
    },
    "env": {
      "GOYOKE_PROJECT_DIR": "${TEMP_DIR}"
    }
  },
  "input": {
    "session_id": "test-session-s004",
    "hook_event_name": "SessionEnd",
    "captured_at": 1705708900
  },
  "expected": {
    "files_created": [
      ".claude/memory/handoffs.jsonl",
      ".claude/memory/last-handoff.md"
    ],
    "handoff_fields": {
      "schema_version": "1.2",
      "violations_count": 1,
      "sharp_edges_count": 1,
      "has_decisions": true
    },
    "exit_code": 0
  },
  "notes": "Tests that goyoke-archive handles multiple artifact types in a single session"
}
