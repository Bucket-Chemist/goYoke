{
  "id": "F002_threshold_reached",
  "description": "Third consecutive failure with SAME error type triggers sharp edge capture",
  "setup": {
    "create_dirs": [".claude/memory", ".goyoke"],
    "files": {
      ".goyoke/failure-tracker.jsonl": "{\"timestamp\":1705708790,\"file\":\"test.py\",\"tool\":\"Bash\",\"error_type\":\"general_error\"}\n{\"timestamp\":1705708795,\"file\":\"test.py\",\"tool\":\"Bash\",\"error_type\":\"general_error\"}\n"
    },
    "env": {
      "GOYOKE_PROJECT_DIR": "${TEMP_DIR}",
      "GOYOKE_STORAGE_PATH": "${TEMP_DIR}/.goyoke/failure-tracker.jsonl",
      "GOYOKE_MAX_FAILURES": "3",
      "GOYOKE_FAILURE_WINDOW": "999999999"
    }
  },
  "input": {
    "tool_name": "Bash",
    "tool_input": {"command": "python test.py"},
    "tool_response": {"exit_code": 1, "output": "TypeError: expected str"},
    "session_id": "test-f002",
    "hook_event_name": "PostToolUse",
    "captured_at": 1705708800
  },
  "expected": {
    "exit_code": 0,
    "files_created": [".claude/memory/pending-learnings.jsonl"],
    "file_contains": {
      ".claude/memory/pending-learnings.jsonl": [
        "\"file\":\"test.py\"",
        "\"error_type\":",
        "\"consecutive_failures\":3",
        "\"timestamp\":1705708800"
      ]
    },
    "stdout_contains": ["SHARP EDGE", "block", "DEBUGGING LOOP"]
  }
}
